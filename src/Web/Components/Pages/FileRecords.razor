@page "/file-records"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Fichas de Arquivo</PageTitle>

<div class="page-header">
    <div>
        <h1>Fichas de Arquivo</h1>
        <p class="page-subtitle">Gerencie seus registros de arte final</p>
    </div>
    <a href="/file-records/new" class="btn btn-primary btn-new" aria-label="Criar nova ficha de arquivo">
        <span class="btn-icon" aria-hidden="true">+</span>
        <span>Nova Ficha</span>
    </a>
</div>

@if (IsLoading)
{
    <div class="loading-state" role="status" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <p>Carregando fichas...</p>
    </div>
}
else if (HasError)
{
    <div class="error-state" role="alert">
        <div class="state-icon" aria-hidden="true">⚠️</div>
        <p class="state-title">Erro ao carregar fichas</p>
        <p class="state-description">Não foi possível conectar ao servidor. Verifique sua conexão e tente novamente.</p>
        <button class="btn btn-outline-primary" @onclick="LoadRecords">Tentar novamente</button>
    </div>
}
else if (Records is null || Records.Count == 0)
{
    <div class="empty-state" role="status">
        <div class="state-icon" aria-hidden="true">📁</div>
        <p class="state-title">Nenhuma ficha cadastrada</p>
        <p class="state-description">Comece adicionando seu primeiro registro de arte final.</p>
        <a href="/file-records/new" class="btn btn-primary">Criar primeira ficha</a>
    </div>
}
else
{
    <div class="records-summary">
        <span>@Records.Count @(Records.Count == 1 ? "registro" : "registros")</span>
    </div>

    @* Desktop table view *@
    <div class="table-container">
        <table class="records-table" aria-label="Lista de fichas de arquivo">
            <thead>
                <tr>
                    <th scope="col">Nome</th>
                    <th scope="col">Tipo</th>
                    <th scope="col">Nº Arquivo</th>
                    <th scope="col">Cliente</th>
                    <th scope="col">Data</th>
                    <th scope="col" class="col-disk">Nº Disquete</th>
                    <th scope="col" class="col-actions">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Records)
                {
                    <tr>
                        <td class="cell-name">@record.Name</td>
                        <td><span class="badge-type badge-@record.FileType.ToString().ToLowerInvariant()">@record.FileType</span></td>
                        <td>@(record.FileNumber ?? "—")</td>
                        <td>@record.Client</td>
                        <td class="cell-date">@(record.Date?.ToString("dd/MM/yyyy") ?? "Sem data")</td>
                        <td class="col-disk">@(record.FlopDiskNumber?.ToString() ?? "—")</td>
                        <td class="col-actions">
                            <div class="action-group">
                                <a href="@($"/file-records/{record.Id}/edit")" class="btn-action btn-edit" title="Editar" aria-label="Editar @record.Name">
                                    ✏️
                                </a>
                                <button class="btn-action btn-delete" @onclick="() => RequestDelete(record.Id, record.Name)" title="Excluir" aria-label="Excluir @record.Name">
                                    🗑️
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Mobile card view *@
    <div class="cards-container">
        @foreach (var record in Records)
        {
            <div class="record-card">
                <div class="card-header">
                    <span class="card-name">@record.Name</span>
                    <span class="badge-type badge-@record.FileType.ToString().ToLowerInvariant()">@record.FileType</span>
                </div>
                <div class="card-details">
                    <div class="card-detail">
                        <span class="detail-label">Cliente</span>
                        <span class="detail-value">@record.Client</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(record.FileNumber))
                    {
                        <div class="card-detail">
                            <span class="detail-label">Arquivo</span>
                            <span class="detail-value">@record.FileNumber</span>
                        </div>
                    }
                    <div class="card-detail">
                        <span class="detail-label">Data</span>
                        <span class="detail-value">@(record.Date?.ToString("dd/MM/yyyy") ?? "Sem data")</span>
                    </div>
                    @if (record.FlopDiskNumber.HasValue)
                    {
                        <div class="card-detail">
                            <span class="detail-label">Disquete</span>
                            <span class="detail-value">#@record.FlopDiskNumber</span>
                        </div>
                    }
                </div>
                <div class="card-actions">
                    <a href="@($"/file-records/{record.Id}/edit")" class="btn btn-sm btn-outline-secondary" aria-label="Editar @record.Name">Editar</a>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(record.Id, record.Name)" aria-label="Excluir @record.Name">Excluir</button>
                </div>
            </div>
        }
    </div>
}

@* Delete Confirmation Modal *@
@if (ShowDeleteModal)
{
    <div class="modal-backdrop" @onclick="CancelDelete" aria-hidden="true"></div>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <div class="modal-content">
            <div class="modal-icon" aria-hidden="true">🗑️</div>
            <h2 id="deleteModalTitle" class="modal-title">Excluir ficha</h2>
            <p class="modal-message">
                Tem certeza que deseja excluir <strong>@DeleteTargetName</strong>? Esta ação não pode ser desfeita.
            </p>
            <div class="modal-actions">
                <button class="btn btn-modal-cancel" @onclick="CancelDelete" disabled="@IsDeleting">
                    Cancelar
                </button>
                <button class="btn btn-modal-delete" @onclick="ConfirmDelete" disabled="@IsDeleting">
                    @if (IsDeleting)
                    {
                        <span class="spinner-sm" aria-hidden="true"></span>
                        <span>Excluindo...</span>
                    }
                    else
                    {
                        <span>Excluir</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
