@page "/file-records"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Fichas de Arquivo</PageTitle>

<div class="page-title-row">
    <h1>Fichas de Arquivo</h1>
    <p class="page-subtitle">Gerencie seus registros de arte final</p>
</div>

<div class="search-row">
    <div class="search-group">
        <input type="text"
               maxlength="200"
               placeholder="Buscar por nome do arquivo ou cliente..."
               aria-label="Buscar fichas de arquivo"
               class="search-input"
               tabindex="0"
               @bind="SearchTerm"
               @bind:event="oninput"
               @onkeydown="HandleSearchKeyDown" />
        <button type="button"
                class="btn btn-primary btn-search"
                aria-label="Executar busca"
                tabindex="0"
                disabled="@IsSearching"
                @onclick="ExecuteSearch">
            @if (IsSearching)
            {
                <span class="spinner-sm" aria-hidden="true"></span>
                <span>Buscando...</span>
            }
            else
            {
                <span class="btn-search-icon" aria-hidden="true">🔍</span>
                <span>Buscar</span>
            }
        </button>
    </div>
    <div class="column-selector" @ref="ColumnSelectorRef" @onkeydown="HandleColumnSelectorKeyDown">
        <button type="button"
                class="btn btn-outline-secondary btn-campos @(IsColumnSelectorOpen ? "active" : "")"
                aria-haspopup="listbox"
                aria-expanded="@IsColumnSelectorOpen.ToString().ToLowerInvariant()"
                aria-controls="column-selector-list"
                aria-label="Selecionar colunas visíveis"
                title="Campos"
                @onclick="ToggleColumnSelector">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
        </button>

        @if (IsColumnSelectorOpen)
        {
            <div class="column-selector-dropdown" id="column-selector-list" role="listbox" aria-label="Selecionar colunas visíveis">
                @foreach (var col in AllColumns)
                {
                    var isDisabled = IsColumnDisabled(col.Id);
                    <label class="column-option @(isDisabled ? "disabled" : "")"
                           role="option"
                           aria-selected="@ColumnVisibility[col.Id].ToString().ToLowerInvariant()">
                        <input type="checkbox"
                               checked="@ColumnVisibility[col.Id]"
                               disabled="@isDisabled"
                               @onchange="() => ToggleColumnVisibility(col.Id)" />
                        @col.Label
                    </label>
                }
            </div>
        }
    </div>
    <a href="/file-records/new" class="btn btn-primary btn-new" aria-label="Criar nova ficha de arquivo" tabindex="0">
        <span class="btn-icon" aria-hidden="true">+</span>
        <span>Nova Ficha</span>
    </a>
</div>

@if (HasSearchError)
{
    <div class="search-error-alert" role="alert" aria-live="assertive">
        <span class="alert-icon" aria-hidden="true">⚠️</span>
        <span>Não foi possível completar a busca. Tente novamente.</span>
    </div>
}

@if (IsLoading)
{
    <div class="loading-state" role="status" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <p>Carregando fichas...</p>
    </div>
}
else if (HasError)
{
    <div class="error-state" role="alert">
        <div class="state-icon" aria-hidden="true">⚠️</div>
        <p class="state-title">Erro ao carregar fichas</p>
        <p class="state-description">Não foi possível conectar ao servidor. Verifique sua conexão e tente novamente.</p>
        <button class="btn btn-outline-primary" @onclick="LoadRecords">Tentar novamente</button>
    </div>
}
else if (IsSearchActive && SearchResultCount == 0)
{
    <div class="empty-state" role="status" aria-live="polite">
        <div class="state-icon" aria-hidden="true">🔍</div>
        <p class="state-title">Nenhum resultado encontrado para '@SearchedTerm'</p>
        <p class="state-description">Tente buscar com outros termos ou verifique a ortografia.</p>
        <button class="btn btn-outline-primary" @onclick="ClearSearch">Limpar busca</button>
    </div>
}
else if (Records is null || Records.Count == 0)
{
    <div class="empty-state" role="status">
        <div class="state-icon" aria-hidden="true">📁</div>
        <p class="state-title">Nenhuma ficha cadastrada</p>
        <p class="state-description">Comece adicionando seu primeiro registro de arte final.</p>
        <a href="/file-records/new" class="btn btn-primary">Criar primeira ficha</a>
    </div>
}
else
{
    <div class="records-summary">
        @if (IsSearchActive && SearchResultCount > 0)
        {
            <span>@SearchResultCount @(SearchResultCount == 1 ? "resultado" : "resultados") para '@SearchedTerm'</span>
            <button class="btn-clear-search" @onclick="ClearSearch" aria-label="Limpar busca e mostrar todos os registros">
                ✕ Limpar busca
            </button>
        }
        else
        {
            <span>@TotalCount @(TotalCount == 1 ? "registro" : "registros")</span>
        }
    </div>

    @* Desktop table view *@
    <div class="table-container">
        <table class="records-table" aria-label="Lista de fichas de arquivo">
            <thead>
                <tr>
                    @if (IsColumnVisible("name")) { <th scope="col">Nome</th> }
                    @if (IsColumnVisible("type")) { <th scope="col">Tipo</th> }
                    @if (IsColumnVisible("fileNumber")) { <th scope="col">Nº Arquivo</th> }
                    @if (IsColumnVisible("client")) { <th scope="col">Cliente</th> }
                    @if (IsColumnVisible("date")) { <th scope="col">Data</th> }
                    @if (IsColumnVisible("flopDiskNumber")) { <th scope="col" class="col-disk">Nº Disquete</th> }
                    @if (IsColumnVisible("actions")) { <th scope="col" class="col-actions">Ações</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Records)
                {
                    <tr>
                        @if (IsColumnVisible("name")) { <td class="cell-name">@record.Name</td> }
                        @if (IsColumnVisible("type")) { <td><span class="badge-type badge-@record.FileType.ToString().ToLowerInvariant()">@record.FileType</span></td> }
                        @if (IsColumnVisible("fileNumber")) { <td>@(record.FileNumber ?? "—")</td> }
                        @if (IsColumnVisible("client")) { <td>@record.Client</td> }
                        @if (IsColumnVisible("date")) { <td class="cell-date">@(record.Date?.ToString("dd/MM/yyyy") ?? "Sem data")</td> }
                        @if (IsColumnVisible("flopDiskNumber")) { <td class="col-disk">@(record.FlopDiskNumber?.ToString() ?? "—")</td> }
                        @if (IsColumnVisible("actions"))
                        {
                            <td class="col-actions">
                                <div class="action-group">
                                    <a href="@($"/file-records/{record.Id}/edit")" class="btn-action btn-edit" title="Editar" aria-label="Editar @record.Name">
                                        ✏️
                                    </a>
                                    <button class="btn-action btn-delete" @onclick="() => RequestDelete(record.Id, record.Name)" title="Excluir" aria-label="Excluir @record.Name">
                                        🗑️
                                    </button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Mobile card view *@
    <div class="cards-container">
        @foreach (var record in Records)
        {
            <div class="record-card">
                <div class="card-header">
                    @if (IsColumnVisible("name"))
                    {
                        <span class="card-name">@record.Name</span>
                    }
                    @if (IsColumnVisible("type"))
                    {
                        <span class="badge-type badge-@record.FileType.ToString().ToLowerInvariant()">@record.FileType</span>
                    }
                </div>
                <div class="card-details">
                    @if (IsColumnVisible("client"))
                    {
                        <div class="card-detail">
                            <span class="detail-label">Cliente</span>
                            <span class="detail-value">@record.Client</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(record.FileNumber) && IsColumnVisible("fileNumber"))
                    {
                        <div class="card-detail">
                            <span class="detail-label">Arquivo</span>
                            <span class="detail-value">@record.FileNumber</span>
                        </div>
                    }
                    @if (IsColumnVisible("date"))
                    {
                        <div class="card-detail">
                            <span class="detail-label">Data</span>
                            <span class="detail-value">@(record.Date?.ToString("dd/MM/yyyy") ?? "Sem data")</span>
                        </div>
                    }
                    @if (record.FlopDiskNumber.HasValue && IsColumnVisible("flopDiskNumber"))
                    {
                        <div class="card-detail">
                            <span class="detail-label">Disquete</span>
                            <span class="detail-value">#@record.FlopDiskNumber</span>
                        </div>
                    }
                </div>
                @if (IsColumnVisible("actions"))
                {
                    <div class="card-actions">
                        <a href="@($"/file-records/{record.Id}/edit")" class="btn btn-sm btn-outline-secondary" aria-label="Editar @record.Name">Editar</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(record.Id, record.Name)" aria-label="Excluir @record.Name">Excluir</button>
                    </div>
                }
            </div>
        }
    </div>

    @* Infinite scroll sentinel and loading indicator *@
    @if (IsLoadingMore)
    {
        <div class="loading-more" role="status" aria-live="polite">
            <div class="spinner-sm" aria-hidden="true"></div>
            <span>Carregando mais registros...</span>
        </div>
    }

    <div @ref="SentinelRef" class="scroll-sentinel" aria-hidden="true"></div>
}

@* Delete Confirmation Modal *@
@if (ShowDeleteModal)
{
    <div class="modal-backdrop" @onclick="CancelDelete" aria-hidden="true"></div>
    <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <div class="modal-content">
            <div class="modal-icon" aria-hidden="true">🗑️</div>
            <h2 id="deleteModalTitle" class="modal-title">Excluir ficha</h2>
            <p class="modal-message">
                Tem certeza que deseja excluir <strong>@DeleteTargetName</strong>? Esta ação não pode ser desfeita.
            </p>
            <div class="modal-actions">
                <button class="btn btn-modal-cancel" @onclick="CancelDelete" disabled="@IsDeleting">
                    Cancelar
                </button>
                <button class="btn btn-modal-delete" @onclick="ConfirmDelete" disabled="@IsDeleting">
                    @if (IsDeleting)
                    {
                        <span class="spinner-sm" aria-hidden="true"></span>
                        <span>Excluindo...</span>
                    }
                    else
                    {
                        <span>Excluir</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
